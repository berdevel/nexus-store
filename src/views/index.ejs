<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Nexus Store</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 40px; background-color: #f9f9f9; }
        .container { max-width: 600px; background: white; padding: 20px; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
        form { margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid #eee; }
        input { display: block; margin: 10px 0; padding: 8px; width: 95%; }
        button { background: #28a745; color: white; border: none; padding: 10px 15px; cursor: pointer; border-radius: 4px; }
    </style>
</head>
<body>
    <div class="container">
        <h1>Nexus Store 🚀</h1>
        
        <h3>Agregar Nuevo Producto</h3>
        <form action="/products" method="POST">
            <input type="text" name="name" placeholder="Nombre del producto" required>
            <input type="number" name="price" placeholder="Precio ($)" required>
            <button type="submit">Guardar Producto</button>
        </form>

        <h3>Catálogo disponible</h3>
        <ul>
            <% products.forEach(p => { %>
                <li><strong><%= p.name %></strong> - $<%= p.price %></li>
            <% }) %>
        </ul>

        <p><a href="/api/products" target="_blank">Ver respuestas en crudo de la API (JSON)</a></p>
    </div>
</body>
</html>